{
  "hardware": "M2 MacBook Pro, 16GB RAM, Apple NVMe SSD",
  "benchmarks": [
    {
      "metric": "v1 fsync-per-write throughput",
      "value": "3,200",
      "unit": "writes/sec",
      "note": "Limited by fsync latency ~310μs — not by CPU or memory"
    },
    {
      "metric": "v2 group commit (batch=8)",
      "value": "18,400",
      "unit": "writes/sec",
      "note": "5.75× improvement. One fsync per 8 records."
    },
    {
      "metric": "v2 group commit (batch=32)",
      "value": "67,000",
      "unit": "writes/sec",
      "note": "21× improvement. Batch size is the dominant lever."
    },
    {
      "metric": "v2 group commit (batch=64)",
      "value": "112,000",
      "unit": "writes/sec",
      "note": "35× improvement over v1. Diminishing returns start here."
    },
    {
      "metric": "v1 append latency (p50)",
      "value": "312",
      "unit": "μs",
      "note": "Almost entirely fsync latency"
    },
    {
      "metric": "v2 append latency (p50, batch=32)",
      "value": "14",
      "unit": "μs",
      "note": "Per-record cost once amortized across the batch"
    },
    {
      "metric": "Recovery speed",
      "value": "1.4",
      "unit": "GB/s",
      "note": "Sequential reads from NVMe; 1M records recovered in ~420ms"
    }
  ]
}
