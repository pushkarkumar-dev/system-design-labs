---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import LabCard from '../../components/ui/LabCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const cats = [
    { slug: 'storage',        label: 'Storage & Data',        desc: 'Write-ahead logs, B-trees, LSM-trees, column stores, document stores, time-series, and more.' },
    { slug: 'distributed',    label: 'Distributed Systems',   desc: 'Raft consensus, CRDTs, consistent hashing, gossip, distributed locks, sagas, and logical clocks.' },
    { slug: 'messaging',      label: 'Messaging & Streaming', desc: 'Message queues, pub/sub brokers, stream processors, and Kafka-lite implementations.' },
    { slug: 'networking',     label: 'Networking & Web',      desc: 'HTTP servers, WebSocket gateways, load balancers, CDN edge nodes, DNS resolvers, and a userspace TCP stack.' },
    { slug: 'platform',       label: 'Platform & Infra',      desc: 'Container runtimes, orchestrators, CI/CD engines, feature flags, service discovery, and observability stacks.' },
    { slug: 'runtimes',       label: 'Compilers & Runtimes',  desc: 'Bytecode VMs, regex engines, garbage collectors, and tokenizers.' },
    { slug: 'security',       label: 'Security & Identity',   desc: 'JWT libraries, OAuth providers, and password hashing — Java co-primary.' },
    { slug: 'ai-foundations', label: 'AI Foundations',        desc: 'Transformers, RAG pipelines, embedding pipelines, LLM inference, speculative decoding, and more.' },
    { slug: 'local-genai',    label: 'Local GenAI',           desc: 'Run models locally: LoRA fine-tuning, ComfyUI DAGs, ControlNet, SD fine-tuning, multimodal servers, and voice assistants.' },
  ];
  return cats.map(c => ({ params: { cat: c.slug }, props: c }));
}

const { slug, label, desc } = Astro.props;

const allLabs = await getCollection('labs');
const labs = allLabs
  .filter(l => l.data.category === slug)
  .sort((a, b) => a.data.publishedAt.localeCompare(b.data.publishedAt));

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${label} Labs — build.labs`} description={desc}>
  <Header />

  <main>
    <div class="cat-page">
      <div class="cat-breadcrumb">
        <a href={base}>All Labs</a>
        <span>›</span>
        <span>{label}</span>
      </div>

      <h1 class="cat-title">{label}</h1>
      <p class="cat-desc">{desc}</p>
      <p class="cat-count">{labs.length} lab{labs.length !== 1 ? 's' : ''}</p>

      <div class="labs-grid">
        {labs.map(lab => (
          <LabCard
            slug={lab.data.slug}
            title={lab.data.title}
            category={lab.data.category}
            difficulty={lab.data.difficulty}
            language={lab.data.language}
            estimatedHours={lab.data.estimatedHours}
            topBenchmark={lab.data.benchmarks[0] ? `${lab.data.benchmarks[0].value} ${lab.data.benchmarks[0].unit}` : undefined}
            summary={lab.data.summary}
            published={true}
          />
        ))}
      </div>

      <a href={base} class="back-link">← All labs</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
.cat-page {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2.5rem 1.5rem 5rem;
}
.cat-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: var(--ink-4);
  margin-bottom: 1.5rem;
}
.cat-breadcrumb a {
  color: var(--accent);
  text-decoration: none;
}
.cat-breadcrumb a:hover { text-decoration: underline; }

.cat-title {
  font-family: 'Source Serif 4 Variable', Georgia, serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 0.75rem;
}
.cat-desc {
  font-size: 1rem;
  color: var(--ink-3);
  line-height: 1.65;
  max-width: 65ch;
  margin-bottom: 0.5rem;
}
.cat-count {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: var(--ink-4);
  margin-bottom: 2rem;
}

.labs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
  margin-bottom: 2.5rem;
}

.back-link {
  font-size: 0.85rem;
  color: var(--accent);
  text-decoration: none;
}
.back-link:hover { text-decoration: underline; }
</style>
