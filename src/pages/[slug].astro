---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Badge from '../components/ui/Badge.astro';
import LabStage from '../components/lab/LabStage.astro';
import Benchmark from '../components/lab/Benchmark.astro';
import RunIt from '../components/lab/RunIt.astro';
import WhatSurprisedMe from '../components/lab/WhatSurprisedMe.astro';
import WhatTheToyMisses from '../components/lab/WhatTheToyMisses.astro';
import JavaIntegration from '../components/lab/JavaIntegration.astro';

export async function getStaticPaths() {
  const labs = await getCollection('labs');
  return labs.map(lab => ({
    params: { slug: lab.data.slug },
    props: { lab },
  }));
}

const { lab } = Astro.props;
const { data } = lab;
const { Content, headings } = await render(lab);

const base = import.meta.env.BASE_URL;
const tocHeadings = headings.filter(h => h.depth === 2);
---

<BaseLayout
  title={`${data.title} — build.labs`}
  description={data.summary}
>
  <Header />

  <div class="lab-page">
    <!-- ── Hero ───────────────────────────── -->
    <div class="lab-hero">
      <div class="lab-hero-inner">
        <div class="lab-breadcrumb">
          <a href={base}>Labs</a>
          <span>›</span>
          <span>{data.category}</span>
        </div>
        <h1 class="lab-headline">{data.title}</h1>
        <p class="lab-summary">{data.summary}</p>
        <div class="lab-badges">
          <Badge variant="lang" lang={data.language} label={`${data.language} ${data.language === 'rust' ? '1.83' : data.language === 'go' ? '1.23' : data.language === 'python' ? '3.12' : '17'}`} />
          <Badge variant="diff" diff={data.difficulty} label={data.difficulty} />
          <span class="badge-hours">~{data.estimatedHours.building}h build · ~{data.estimatedHours.reading}h read</span>
          <span class="badge-loc">~{data.loc} LoC (v3)</span>
        </div>
        <div class="lab-stages-strip">
          {data.stages.map(s => (
            <Badge variant="stage" stage={s.id} label={`${s.id}: ${s.title}`} />
          ))}
        </div>
        {data.javaIntegration && (
          <div class="lab-java-flag">
            <span class="java-flag-icon">☕</span>
            <span class="java-flag-label">Java/Spring integration included</span>
            <span class="java-flag-type">{data.javaIntegration.type.replace('-', ' ')}</span>
          </div>
        )}
      </div>
    </div>

    <div class="lab-body">
      <!-- ── TOC sidebar ─────────────────── -->
      <aside class="lab-toc">
        <div class="toc-inner">
          <p class="toc-label">Contents</p>
          <nav>
            <ul class="toc-list">
              {tocHeadings.map(h => (
                <li>
                  <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
          {data.benchmarks.length > 0 && (
            <div class="toc-bench-preview">
              <p class="toc-bench-label">Top benchmark</p>
              <p class="toc-bench-val">
                <span class="toc-bench-number">{data.benchmarks[0].value}</span>
                <span class="toc-bench-unit"> {data.benchmarks[0].unit}</span>
              </p>
              <p class="toc-bench-metric">{data.benchmarks[0].metric}</p>
            </div>
          )}
          <a
            href={`https://github.com/pushkarkumar-dev/system-design-labs/tree/main/labs/${data.slug}`}
            class="toc-repo-link"
            target="_blank"
            rel="noopener"
          >
            View source ↗
          </a>
        </div>
      </aside>

      <!-- ── Main content ────────────────── -->
      <article class="lab-content prose">
        <Content
          components={{
            LabStage,
            Benchmark,
            RunIt,
            WhatSurprisedMe,
            WhatTheToyMisses,
            JavaIntegration,
          }}
        />
      </article>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
.lab-page { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

/* ── Hero ── */
.lab-hero {
  padding: 3rem 0 2rem;
  border-bottom: 1px solid var(--line);
}
.lab-hero-inner { max-width: 780px; }

.lab-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: var(--ink-4);
  margin-bottom: 1rem;
}
.lab-breadcrumb a { color: var(--ink-3); text-decoration: none; }
.lab-breadcrumb a:hover { color: var(--accent); }

.lab-headline {
  font-family: 'Source Serif 4 Variable', Georgia, serif;
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 0.75rem;
  line-height: 1.22;
}
.lab-summary {
  font-size: 1rem;
  color: var(--ink-3);
  line-height: 1.65;
  max-width: 68ch;
  margin-bottom: 1.25rem;
}
.lab-badges {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
  margin-bottom: 0.875rem;
}
.badge-hours, .badge-loc {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: var(--ink-4);
}
.lab-stages-strip {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.lab-java-flag {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(232,160,48,0.08);
  border: 1px solid rgba(232,160,48,0.25);
  border-radius: var(--r-sm);
  padding: 0.35rem 0.75rem;
  font-size: 0.8rem;
}
.java-flag-icon { font-size: 0.95rem; }
.java-flag-label { color: var(--ink-2); }
.java-flag-type {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  color: var(--java-accent);
  background: rgba(232,160,48,0.10);
  border-radius: 999px;
  padding: 0.1rem 0.4rem;
}

/* ── Body layout ── */
.lab-body {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 3rem;
  padding: 2.5rem 0;
  align-items: start;
}
@media (max-width: 860px) {
  .lab-body { grid-template-columns: 1fr; }
  .lab-toc  { display: none; }
}

/* ── TOC ── */
.lab-toc { position: sticky; top: 76px; }
.toc-inner {
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: var(--r-md);
  padding: 1rem;
}
.toc-label {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--ink-4);
  margin-bottom: 0.75rem;
}
.toc-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.3rem; }
.toc-link {
  font-size: 0.8rem;
  color: var(--ink-3);
  text-decoration: none;
  display: block;
  padding: 0.2rem 0;
  line-height: 1.4;
  transition: color var(--dur-fast);
}
.toc-link:hover { color: var(--accent); }

.toc-bench-preview {
  margin-top: 1rem;
  padding-top: 0.875rem;
  border-top: 1px solid var(--line);
}
.toc-bench-label {
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--ink-4);
  margin-bottom: 0.25rem;
}
.toc-bench-val { margin-bottom: 0.2rem; }
.toc-bench-number {
  font-family: 'Source Serif 4 Variable', serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--accent);
}
.toc-bench-unit { font-size: 0.78rem; color: var(--ink-4); }
.toc-bench-metric { font-size: 0.75rem; color: var(--ink-4); }

.toc-repo-link {
  display: block;
  margin-top: 0.875rem;
  padding-top: 0.875rem;
  border-top: 1px solid var(--line);
  font-size: 0.78rem;
  color: var(--accent);
  text-decoration: none;
}
.toc-repo-link:hover { text-decoration: underline; }
</style>
