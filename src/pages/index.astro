---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Badge from '../components/ui/Badge.astro';
import LabCard from '../components/ui/LabCard.astro';
import { getCollection } from 'astro:content';

const allLabs = await getCollection('labs');
allLabs.sort((a, b) => a.data.publishedAt.localeCompare(b.data.publishedAt));

const categories = [
  { slug: 'storage',        label: 'Storage & Data' },
  { slug: 'distributed',    label: 'Distributed Systems' },
  { slug: 'messaging',      label: 'Messaging & Streaming' },
  { slug: 'networking',     label: 'Networking & Web' },
  { slug: 'platform',       label: 'Platform & Infra' },
  { slug: 'runtimes',       label: 'Compilers & Runtimes' },
  { slug: 'security',       label: 'Security & Identity' },
  { slug: 'ai-foundations', label: 'AI Foundations' },
  { slug: 'local-genai',    label: 'Local GenAI' },
];

const difficulties = [
  { slug: 'intermediate', label: 'Intermediate' },
  { slug: 'advanced',     label: 'Advanced' },
  { slug: 'extreme',      label: 'Extreme' },
];

const languages = [
  { slug: 'rust',   label: 'Rust' },
  { slug: 'go',     label: 'Go' },
  { slug: 'python', label: 'Python' },
  { slug: 'c',      label: 'C' },
];

// Stats for hero
const totalLoc = allLabs.reduce((s, l) => s + (l.data.loc ?? 0), 0);
---

<BaseLayout title="Build Your Own Labs — pushkar.dev">
  <Header />

  <main>
    <!-- ── Hero ─────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-eyebrow">61 labs · actually runnable · with real benchmarks</p>
        <h1 class="hero-title">
          Build foundational<br />
          <em>systems from scratch</em>
        </h1>
        <p class="hero-sub">
          System design teaches you to <em>talk</em> about systems.
          Building from scratch teaches you what those talks were missing.
          Every lab ships working code, profiled benchmarks, and a Java/Spring
          integration you can drop into a real service.
        </p>

        <!-- Terminal animation -->
        <div class="terminal" id="hero-terminal" aria-hidden="true">
          <div class="terminal-bar">
            <span class="tb-dot tb-red"></span>
            <span class="tb-dot tb-yellow"></span>
            <span class="tb-dot tb-green"></span>
            <span class="tb-title">build.labs</span>
          </div>
          <div class="terminal-body" id="terminal-body">
            <span class="tl" id="tl0"></span>
            <span class="tl" id="tl1"></span>
            <span class="tl" id="tl2"></span>
            <span class="tl" id="tl3"></span>
            <span class="tl" id="tl4"></span>
            <span class="tl tl-success" id="tl5"></span>
          </div>
        </div>

        <div class="hero-actions">
          <a href="#labs" class="btn-primary">Browse labs</a>
          <a href="https://pushkarkumar-dev.github.io/system-design" class="btn-secondary" target="_blank" rel="noopener">
            ↗ System Design companion
          </a>
        </div>
        <div class="hero-stats">
          <div class="stat"><span class="stat-n">61</span><span class="stat-l">labs live</span></div>
          <div class="stat"><span class="stat-n">4</span><span class="stat-l">stages each</span></div>
          <div class="stat"><span class="stat-n">{Math.round(totalLoc / 1000)}k</span><span class="stat-l">lines of code</span></div>
          <div class="stat"><span class="stat-n">100%</span><span class="stat-l">Java wiring</span></div>
        </div>
      </div>
    </section>

    <!-- ── Labs section ──────────────────────────────── -->
    <section class="labs-section" id="labs">
      <div class="labs-inner">

        <!-- Filter bar -->
        <div class="filter-bar">
          <div class="filter-group">
            <span class="filter-label">Category</span>
            <div class="filter-chips" data-group="cat">
              <button class="chip chip--active" data-val="all">All</button>
              {categories.map(c => (
                <button class="chip" data-val={c.slug}>{c.label}</button>
              ))}
            </div>
          </div>

          <div class="filter-row-2">
            <div class="filter-group filter-group--inline">
              <span class="filter-label">Difficulty</span>
              <div class="filter-chips" data-group="diff">
                <button class="chip chip--active" data-val="all">Any</button>
                {difficulties.map(d => (
                  <button class="chip" data-val={d.slug}>{d.label}</button>
                ))}
              </div>
            </div>

            <div class="filter-group filter-group--inline">
              <span class="filter-label">Language</span>
              <div class="filter-chips" data-group="lang">
                <button class="chip chip--active" data-val="all">Any</button>
                {languages.map(l => (
                  <button class="chip" data-val={l.slug}>{l.label}</button>
                ))}
              </div>
            </div>

            <div class="filter-group filter-group--search">
              <label class="filter-label" for="lab-search">Search</label>
              <input
                id="lab-search"
                type="search"
                class="search-input"
                placeholder="wal, raft, transformer…"
                autocomplete="off"
                spellcheck="false"
              />
            </div>
          </div>
        </div>

        <!-- Result count -->
        <p class="result-count" id="result-count">{allLabs.length} labs</p>

        <!-- Labs grid -->
        <div class="labs-grid" id="labs-grid">
          {allLabs.map(lab => (
            <div
              class="grid-item"
              data-cat={lab.data.category}
              data-diff={lab.data.difficulty}
              data-lang={lab.data.language}
              data-title={lab.data.title.toLowerCase()}
              data-summary={lab.data.summary.toLowerCase()}
            >
              <LabCard
                slug={lab.data.slug}
                title={lab.data.title}
                category={lab.data.category}
                difficulty={lab.data.difficulty}
                language={lab.data.language}
                estimatedHours={lab.data.estimatedHours}
                topBenchmark={lab.data.benchmarks[0] ? `${lab.data.benchmarks[0].value} ${lab.data.benchmarks[0].unit}` : undefined}
                summary={lab.data.summary}
                published={true}
              />
            </div>
          ))}
        </div>

        <p class="no-results" id="no-results" style="display:none">
          No labs match these filters. <button class="clear-link" id="clear-all">Clear all filters</button>
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
/* ── Hero ── */
.hero {
  padding: 4.5rem 1.5rem 3.5rem;
  text-align: center;
  border-bottom: 1px solid var(--line);
}
.hero-inner { max-width: 740px; margin: 0 auto; }
.hero-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78rem;
  color: var(--accent);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1.25rem;
}
.hero-title {
  font-family: 'Source Serif 4 Variable', Georgia, serif;
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  font-weight: 700;
  line-height: 1.18;
  color: var(--ink);
  margin-bottom: 1.25rem;
}
.hero-title em { color: var(--accent); font-style: normal; }
.hero-sub {
  font-size: 1rem;
  color: var(--ink-3);
  line-height: 1.75;
  max-width: 58ch;
  margin: 0 auto 2rem;
}
.hero-sub em { color: var(--ink-2); font-style: normal; }

/* Terminal */
.terminal {
  background: #0d1117;
  border: 1px solid #30363d;
  border-radius: 10px;
  overflow: hidden;
  max-width: 520px;
  margin: 0 auto 2rem;
  text-align: left;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
.terminal-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  background: #161b22;
  border-bottom: 1px solid #30363d;
}
.tb-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
}
.tb-red    { background: #ff5f57; }
.tb-yellow { background: #febc2e; }
.tb-green  { background: #28c840; }
.tb-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  color: #6e7681;
  margin-left: auto;
  margin-right: auto;
}
.terminal-body {
  padding: 14px 18px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78rem;
  line-height: 1.9;
  min-height: 120px;
}
.tl {
  display: block;
  color: #c9d1d9;
  white-space: pre;
  overflow: hidden;
  max-width: 0;
}
.tl-success { color: #3fb950; }

.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.875rem;
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}
.btn-primary {
  background: var(--accent);
  color: #0a0a0a;
  font-weight: 700;
  font-size: 0.9rem;
  padding: 0.65rem 1.5rem;
  border-radius: var(--r-md);
  text-decoration: none;
  transition: opacity var(--dur-fast);
}
.btn-primary:hover { opacity: 0.88; text-decoration: none; }
.btn-secondary {
  border: 1px solid var(--line-2);
  color: var(--ink-3);
  font-size: 0.88rem;
  padding: 0.6rem 1.25rem;
  border-radius: var(--r-md);
  text-decoration: none;
  transition: border-color var(--dur-fast), color var(--dur-fast);
}
.btn-secondary:hover { border-color: var(--accent-line); color: var(--ink); text-decoration: none; }

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
}
.stat { display: flex; flex-direction: column; align-items: center; }
.stat-n { font-family: 'Source Serif 4 Variable', serif; font-size: 1.75rem; font-weight: 700; color: var(--accent); }
.stat-l { font-size: 0.72rem; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.07em; }

/* ── Filter bar ── */
.labs-section { padding: 2.5rem 1.5rem 5rem; }
.labs-inner { max-width: 1200px; margin: 0 auto; }

.filter-bar {
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: var(--r-md);
  padding: 1.25rem 1.5rem;
  margin-bottom: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.filter-group--inline {
  flex-direction: column;
  gap: 0.5rem;
}
.filter-row-2 {
  display: flex;
  flex-wrap: wrap;
  gap: 1.25rem;
  align-items: flex-start;
}
.filter-group--search {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.filter-label {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--ink-4);
}

.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
}

.chip {
  background: transparent;
  border: 1px solid var(--line-2);
  border-radius: 999px;
  color: var(--ink-3);
  font-size: 0.75rem;
  padding: 0.25rem 0.7rem;
  cursor: pointer;
  transition: color var(--dur-fast), border-color var(--dur-fast), background var(--dur-fast);
  white-space: nowrap;
}
.chip:hover {
  border-color: var(--accent-line);
  color: var(--ink);
}
.chip--active {
  background: var(--accent-soft);
  border-color: var(--accent-line);
  color: var(--accent);
}

.search-input {
  background: var(--bg);
  border: 1px solid var(--line-2);
  border-radius: var(--r-sm);
  color: var(--ink);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8rem;
  padding: 0.35rem 0.75rem;
  width: 220px;
  outline: none;
  transition: border-color var(--dur-fast);
}
.search-input:focus { border-color: var(--accent-line); }
.search-input::placeholder { color: var(--ink-4); }

.result-count {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: var(--ink-4);
  margin-bottom: 1rem;
}

/* ── Grid ── */
.labs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
}
.grid-item { display: contents; }
.grid-item[hidden] { display: none; }

.no-results {
  text-align: center;
  padding: 4rem 0;
  color: var(--ink-4);
  font-size: 0.9rem;
}
.clear-link {
  background: none;
  border: none;
  color: var(--accent);
  cursor: pointer;
  font-size: inherit;
  text-decoration: underline;
  padding: 0;
}
</style>

<script>
// ── Terminal animation ────────────────────────────────
const lines = [
  '$ cargo bench --bench wal_throughput',
  '   WAL append:  2.1M records/sec  ✓',
  '$ go test ./raft/...  ok (47ms leader election)',
  '   Raft consensus:  8/8 tests pass  ✓',
  '$ python -m pytest labs/transformer/ -q',
  '✓ 61 labs built · 0 failures',
];

function runTerminal() {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const els = lines.map((_, i) => document.getElementById(`tl${i}`));
  if (!els[0]) return;

  if (reduced) {
    lines.forEach((text, i) => {
      if (els[i]) { els[i].textContent = text; els[i].style.maxWidth = 'none'; }
    });
    return;
  }

  let delay = 0;
  lines.forEach((text, i) => {
    const el = els[i];
    if (!el) return;
    el.textContent = text;
    const dur = text.length * 18;
    setTimeout(() => {
      el.style.transition = `max-width ${dur}ms steps(${text.length}, end)`;
      el.style.maxWidth = `${text.length}ch`;
    }, delay);
    delay += dur + 120;
  });
}

document.addEventListener('DOMContentLoaded', runTerminal);

// ── Filter logic ──────────────────────────────────────
(function () {
  const grid   = document.getElementById('labs-grid');
  const count  = document.getElementById('result-count');
  const noRes  = document.getElementById('no-results');
  const search = document.getElementById('lab-search') as HTMLInputElement | null;
  const clearAll = document.getElementById('clear-all');
  if (!grid) return;

  const items = Array.from(grid.querySelectorAll('.grid-item')) as HTMLElement[];

  // Active filter state
  const state: Record<string, string> = { cat: 'all', diff: 'all', lang: 'all', q: '' };

  function readFromURL() {
    const p = new URLSearchParams(location.search);
    state.cat  = p.get('cat')  ?? 'all';
    state.diff = p.get('diff') ?? 'all';
    state.lang = p.get('lang') ?? 'all';
    state.q    = p.get('q')    ?? '';
    if (search) search.value = state.q;
    syncChipUI();
  }

  function writeToURL() {
    const p = new URLSearchParams();
    if (state.cat  !== 'all') p.set('cat',  state.cat);
    if (state.diff !== 'all') p.set('diff', state.diff);
    if (state.lang !== 'all') p.set('lang', state.lang);
    if (state.q)              p.set('q',    state.q);
    const qs = p.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  function syncChipUI() {
    document.querySelectorAll<HTMLElement>('[data-group]').forEach(group => {
      const g = group.dataset.group as string;
      const val = state[g] ?? 'all';
      group.querySelectorAll<HTMLElement>('.chip').forEach(chip => {
        chip.classList.toggle('chip--active', chip.dataset.val === val);
      });
    });
  }

  function applyFilters() {
    const q = state.q.toLowerCase().trim();
    let shown = 0;
    items.forEach(item => {
      const catOk  = state.cat  === 'all' || item.dataset.cat  === state.cat;
      const diffOk = state.diff === 'all' || item.dataset.diff === state.diff;
      const langOk = state.lang === 'all' || item.dataset.lang === state.lang;
      const qOk    = !q || (item.dataset.title ?? '').includes(q) || (item.dataset.summary ?? '').includes(q);
      const visible = catOk && diffOk && langOk && qOk;
      item.hidden = !visible;
      if (visible) shown++;
    });
    if (count) count.textContent = `${shown} lab${shown !== 1 ? 's' : ''}`;
    if (noRes)  noRes.style.display = shown === 0 ? '' : 'none';
  }

  function setFilter(group: string, val: string) {
    state[group] = val;
    syncChipUI();
    writeToURL();
    applyFilters();
  }

  // Chip clicks
  document.querySelectorAll<HTMLElement>('[data-group] .chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const group = (chip.closest('[data-group]') as HTMLElement).dataset.group!;
      setFilter(group, chip.dataset.val ?? 'all');
    });
  });

  // Search input (debounced)
  let debounce: ReturnType<typeof setTimeout>;
  search?.addEventListener('input', () => {
    clearTimeout(debounce);
    debounce = setTimeout(() => {
      state.q = search.value;
      writeToURL();
      applyFilters();
    }, 180);
  });

  // Clear all
  clearAll?.addEventListener('click', () => {
    state.cat = 'all'; state.diff = 'all'; state.lang = 'all'; state.q = '';
    if (search) search.value = '';
    syncChipUI();
    writeToURL();
    applyFilters();
  });

  // Browser back/forward
  window.addEventListener('popstate', () => { readFromURL(); applyFilters(); });

  // Initial load
  readFromURL();
  applyFilters();
})();
</script>
