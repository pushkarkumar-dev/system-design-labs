---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Badge from '../components/ui/Badge.astro';
import LabCard from '../components/ui/LabCard.astro';
import { getCollection } from 'astro:content';

const allLabs = await getCollection('labs');
allLabs.sort((a, b) => a.data.publishedAt.localeCompare(b.data.publishedAt));
const publishedSlugs = new Set(allLabs.map(l => l.data.slug));

// Placeholder cards for the full 60-lab roadmap (category buckets)
const categories = [
  { slug: 'storage',       label: 'Storage & Data',       count: 11, lang: 'rust'   as const },
  { slug: 'distributed',   label: 'Distributed Systems',  count: 8,  lang: 'go'     as const },
  { slug: 'messaging',     label: 'Messaging & Streaming', count: 6,  lang: 'go'     as const },
  { slug: 'networking',    label: 'Networking & Web',      count: 7,  lang: 'go'     as const },
  { slug: 'platform',      label: 'Platform & Infra',      count: 8,  lang: 'go'     as const },
  { slug: 'runtimes',      label: 'Compilers & Runtimes',  count: 4,  lang: 'rust'   as const },
  { slug: 'security',      label: 'Security & Identity',   count: 3,  lang: 'java'   as const },
  { slug: 'ai-foundations',label: 'AI Foundations',        count: 10, lang: 'python' as const },
  { slug: 'local-genai',   label: 'Local GenAI',           count: 10, lang: 'python' as const },
];
---

<BaseLayout title="Build Your Own Labs — pushkar.dev">
  <Header />

  <main>
    <!-- ── Hero ───────────────────────────────────── -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-eyebrow">60 labs · actually runnable · with real benchmarks</p>
        <h1 class="hero-title">
          Build foundational<br />
          <em>systems from scratch</em>
        </h1>
        <p class="hero-sub">
          System design teaches you to <em>talk</em> about systems.
          Building from scratch teaches you what those talks were missing.
          Every lab ships working code, profiled benchmarks, and a Java/Spring
          integration you can drop into a real service.
        </p>
        <div class="hero-actions">
          <a href="#labs" class="btn-primary">Browse labs</a>
          <a href="https://pushkar1005.github.io/system-design" class="btn-secondary" target="_blank" rel="noopener">
            ↗ System Design companion
          </a>
        </div>
        <div class="hero-stats">
          <div class="stat"><span class="stat-n">60</span><span class="stat-l">labs total</span></div>
          <div class="stat"><span class="stat-n">{allLabs.length}</span><span class="stat-l">live now</span></div>
          <div class="stat"><span class="stat-n">4</span><span class="stat-l">stages per lab</span></div>
          <div class="stat"><span class="stat-n">100%</span><span class="stat-l">Java wiring</span></div>
        </div>
      </div>
    </section>

    <!-- ── Labs grid ──────────────────────────────── -->
    <section class="labs-section" id="labs">
      <div class="labs-inner">
        <div class="labs-header">
          <h2 class="labs-title">Labs</h2>
          <div class="filter-row" id="filter-row">
            <button class="filter-btn filter-btn--active" data-cat="all">All</button>
            {categories.map(c => (
              <button class="filter-btn" data-cat={c.slug}>{c.label}</button>
            ))}
          </div>
        </div>

        <div class="labs-grid" id="labs-grid">
          {/* Published labs */}
          {allLabs.map(lab => (
            <LabCard
              slug={lab.data.slug}
              title={lab.data.title}
              category={lab.data.category}
              difficulty={lab.data.difficulty}
              language={lab.data.language}
              estimatedHours={lab.data.estimatedHours}
              topBenchmark={lab.data.benchmarks[0] ? `${lab.data.benchmarks[0].value} ${lab.data.benchmarks[0].unit}` : undefined}
              summary={lab.data.summary}
              published={true}
            />
          ))}

          {/* Coming-soon placeholder cards */}
          {categories.flatMap(cat =>
            Array.from({ length: cat.count }).map((_, i) => {
              // Skip if a published lab fills this slot
              return (
                <LabCard
                  slug={`${cat.slug}-placeholder-${i}`}
                  title={`${cat.label} lab ${i + 1}`}
                  category={cat.slug}
                  difficulty="advanced"
                  language={cat.lang}
                  estimatedHours={{ reading: 0, building: 0 }}
                  summary="Coming soon — part of the core 60-lab wave."
                  published={false}
                />
              );
            })
          )}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
/* ── Hero ── */
.hero {
  padding: 5rem 1.5rem 4rem;
  text-align: center;
  border-bottom: 1px solid var(--line);
}
.hero-inner { max-width: 740px; margin: 0 auto; }
.hero-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78rem;
  color: var(--accent);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1.25rem;
}
.hero-title {
  font-family: 'Source Serif 4 Variable', Georgia, serif;
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  font-weight: 700;
  line-height: 1.18;
  color: var(--ink);
  margin-bottom: 1.25rem;
}
.hero-title em { color: var(--accent); font-style: normal; }
.hero-sub {
  font-size: 1rem;
  color: var(--ink-3);
  line-height: 1.75;
  max-width: 60ch;
  margin: 0 auto 2rem;
}
.hero-sub em { color: var(--ink-2); font-style: normal; }
.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.875rem;
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}
.btn-primary {
  background: var(--accent);
  color: #0a0a0a;
  font-weight: 700;
  font-size: 0.9rem;
  padding: 0.65rem 1.5rem;
  border-radius: var(--r-md);
  text-decoration: none;
  transition: opacity var(--dur-fast);
}
.btn-primary:hover { opacity: 0.88; text-decoration: none; }
.btn-secondary {
  border: 1px solid var(--line-2);
  color: var(--ink-3);
  font-size: 0.88rem;
  padding: 0.6rem 1.25rem;
  border-radius: var(--r-md);
  text-decoration: none;
  transition: border-color var(--dur-fast), color var(--dur-fast);
}
.btn-secondary:hover { border-color: var(--accent-line); color: var(--ink); text-decoration: none; }

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
}
.stat { display: flex; flex-direction: column; align-items: center; }
.stat-n { font-family: 'Source Serif 4 Variable', serif; font-size: 1.75rem; font-weight: 700; color: var(--accent); }
.stat-l { font-size: 0.72rem; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.07em; }

/* ── Labs section ── */
.labs-section { padding: 3rem 1.5rem 5rem; }
.labs-inner { max-width: 1200px; margin: 0 auto; }
.labs-header { margin-bottom: 1.75rem; }
.labs-title { font-size: 1.4rem; margin-bottom: 1rem; }

.filter-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.filter-btn {
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--ink-3);
  font-size: 0.78rem;
  padding: 0.3rem 0.85rem;
  cursor: pointer;
  transition: color var(--dur-fast), border-color var(--dur-fast), background var(--dur-fast);
}
.filter-btn:hover, .filter-btn--active {
  background: var(--accent-soft);
  border-color: var(--accent-line);
  color: var(--accent);
}

.labs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
}
</style>

<script is:inline>
// Client-side category filtering
const btns = document.querySelectorAll('.filter-btn');
const cards = document.querySelectorAll('.labs-grid > *');

btns.forEach(btn => {
  btn.addEventListener('click', () => {
    btns.forEach(b => b.classList.remove('filter-btn--active'));
    btn.classList.add('filter-btn--active');

    const cat = btn.dataset.cat;
    cards.forEach(card => {
      const cardCat = card.querySelector('.meta-cat')?.textContent?.trim().toLowerCase().replace(/\s+/g, '-') ?? '';
      card.style.display = (cat === 'all' || cardCat.includes(cat)) ? '' : 'none';
    });
  });
});
</script>
