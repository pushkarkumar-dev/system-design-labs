---
interface Step { label: string; cmd: string; note?: string; }
interface Props {
  repoPath: string;
  prereqs: string[];
  steps: Step[];
  expectedOutput?: string;
}
const { repoPath, prereqs, steps, expectedOutput } = Astro.props;
---
<div class="run-it">
  <div class="run-header">
    <span class="run-title">Run it yourself</span>
    <a
      href={`https://github.com/pushkar1005/system-design-labs/tree/main/${repoPath}`}
      class="run-repo-link"
      target="_blank"
      rel="noopener"
    >
      <code>labs/{repoPath.replace('labs/', '')}</code> ↗
    </a>
  </div>

  <div class="run-prereqs">
    <span class="prereq-label">Prereqs:</span>
    {prereqs.map(p => <code class="prereq-item">{p}</code>)}
  </div>

  <ol class="run-steps">
    {steps.map((step, i) => (
      <li class="run-step">
        <span class="step-num">{i + 1}</span>
        <div class="step-body">
          <span class="step-label">{step.label}</span>
          <pre class="step-cmd"><code>{step.cmd}</code></pre>
          {step.note && <p class="step-note">{step.note}</p>}
        </div>
      </li>
    ))}
  </ol>

  {expectedOutput && (
    <div class="run-output">
      <span class="output-label">Expected output</span>
      <pre class="output-pre"><code>{expectedOutput}</code></pre>
    </div>
  )}
</div>

<style>
.run-it {
  border: 1px solid var(--line-2);
  border-radius: var(--r-md);
  overflow: hidden;
  margin: 1.5rem 0;
}
.run-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1rem;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--line);
}
.run-title {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ink-3);
}
.run-repo-link {
  font-size: 0.8rem;
  color: var(--accent);
  text-decoration: none;
}
.run-repo-link code { background: none; border: none; color: inherit; }
.run-repo-link:hover { text-decoration: underline; }

.run-prereqs {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  padding: 0.6rem 1rem;
  border-bottom: 1px solid var(--line);
  background: var(--bg-card);
}
.prereq-label { font-size: 0.75rem; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.07em; }
.prereq-item {
  font-size: 0.78rem;
  background: var(--bg-raised);
  border: 1px solid var(--line-2);
  border-radius: var(--r-sm);
  padding: 0.15rem 0.45rem;
  color: var(--ink-3);
}

.run-steps {
  list-style: none;
  padding: 0.75rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}
.run-step {
  display: flex;
  gap: 0.875rem;
  align-items: flex-start;
}
.step-num {
  min-width: 1.5rem;
  height: 1.5rem;
  border-radius: 50%;
  background: var(--accent-soft);
  color: var(--accent);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 0.1rem;
}
.step-body { flex: 1; }
.step-label { font-size: 0.82rem; color: var(--ink-3); display: block; margin-bottom: 0.35rem; }
.step-cmd {
  background: var(--code-bg);
  border: 1px solid var(--line);
  border-radius: var(--r-sm);
  padding: 0.5rem 0.75rem;
  font-size: 0.82rem;
  overflow-x: auto;
  margin: 0 0 0.35rem;
}
.step-note { font-size: 0.78rem; color: var(--ink-4); margin: 0; }

.run-output { padding: 0 1rem 0.75rem; }
.output-label {
  display: block;
  font-size: 0.72rem;
  color: var(--ink-4);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin-bottom: 0.4rem;
}
.output-pre {
  background: var(--code-bg);
  border: 1px solid var(--line);
  border-radius: var(--r-sm);
  padding: 0.75rem;
  font-size: 0.8rem;
  overflow-x: auto;
}
</style>
