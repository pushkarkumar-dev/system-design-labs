---
// Three formats (matches javaIntegration.type in frontmatter):
//   service-client  — Java client class + Spring Boot wiring
//   jvm-perspective — JVM/HotSpot comparison (runtimes/compilers labs)
//   co-primary      — Go ref + Spring Security impl side-by-side (security labs)
interface Props {
  type: 'service-client' | 'jvm-perspective' | 'co-primary';
  springModule?: string;
  mavenCoords?: string[];
  repoPath?: string;
}
const { type, springModule, mavenCoords, repoPath } = Astro.props;
---
<section class="java-integration">
  <div class="ji-header">
    <div class="ji-title-row">
      <span class="ji-icon">☕</span>
      <h2 class="ji-title">Wiring it into a Java/Spring service</h2>
    </div>
    <div class="ji-meta">
      <span class={`ji-type ji-type--${type}`}>{type.replace('-', ' ')}</span>
      {springModule && <span class="ji-spring">{springModule}</span>}
    </div>
  </div>

  {mavenCoords && mavenCoords.length > 0 && (
    <div class="ji-maven">
      <span class="ji-maven-label">Maven dependencies</span>
      <div class="ji-maven-coords">
        {mavenCoords.map(c => (
          <div class="maven-coord">
            <code>{c}</code>
          </div>
        ))}
      </div>
    </div>
  )}

  {repoPath && (
    <div class="ji-repo-link">
      <a
        href={`https://github.com/pushkarkumar-dev/system-design-labs/tree/main/${repoPath}`}
        target="_blank"
        rel="noopener"
        class="ji-repo-btn"
      >
        <code>labs/{repoPath.replace('labs/', '')}</code>
        <span class="ji-repo-icon">↗</span>
      </a>
      <span class="ji-repo-hint">Clone and run: <code>cd {repoPath.replace('labs/', 'labs/')} && mvn spring-boot:run</code></span>
    </div>
  )}

  <div class="ji-content prose">
    <slot />
  </div>
</section>

<style>
.java-integration {
  border: 1px solid var(--java-line);
  border-radius: var(--r-md);
  overflow: hidden;
  margin: 2rem 0;
  background: linear-gradient(135deg, rgba(232,160,48,0.03) 0%, transparent 60%);
}

.ji-header {
  padding: 1rem 1.25rem;
  background: rgba(232, 160, 48, 0.06);
  border-bottom: 1px solid var(--java-line);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
}
.ji-title-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.ji-icon { font-size: 1.2rem; }
.ji-title {
  font-family: 'Source Serif 4 Variable', Georgia, serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--ink);
  margin: 0;
}

.ji-meta { display: flex; align-items: center; gap: 0.6rem; }
.ji-type {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  padding: 0.2rem 0.55rem;
  border-radius: 999px;
  font-weight: 500;
}
.ji-type--service-client  { background: rgba(232,160,48,0.15); color: #e8a030; border: 1px solid rgba(232,160,48,0.3); }
.ji-type--jvm-perspective { background: rgba(122,166,194,0.12); color: #7aa6c2; border: 1px solid rgba(122,166,194,0.3); }
.ji-type--co-primary      { background: rgba(143,176,134,0.12); color: #8fb086; border: 1px solid rgba(143,176,134,0.3); }

.ji-spring {
  font-size: 0.75rem;
  color: var(--ink-4);
  font-family: 'JetBrains Mono', monospace;
}

/* Maven coords */
.ji-maven {
  padding: 0.75rem 1.25rem;
  border-bottom: 1px solid var(--line);
  background: var(--bg-card);
}
.ji-maven-label {
  display: block;
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ink-4);
  margin-bottom: 0.5rem;
}
.ji-maven-coords { display: flex; flex-direction: column; gap: 0.35rem; }
.maven-coord code {
  font-size: 0.8rem;
  color: var(--java-accent);
  background: rgba(232,160,48,0.06);
  border-color: rgba(232,160,48,0.15);
}

/* Repo link */
.ji-repo-link {
  padding: 0.65rem 1.25rem;
  border-bottom: 1px solid var(--line);
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
  background: var(--bg-card);
}
.ji-repo-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  background: rgba(232,160,48,0.10);
  border: 1px solid rgba(232,160,48,0.28);
  border-radius: var(--r-sm);
  padding: 0.3rem 0.75rem;
  color: var(--java-accent);
  font-size: 0.8rem;
  text-decoration: none;
  transition: background var(--dur-fast);
}
.ji-repo-btn:hover { background: rgba(232,160,48,0.18); text-decoration: none; }
.ji-repo-btn code { background: none; border: none; color: inherit; padding: 0; }
.ji-repo-icon { font-size: 0.8rem; }
.ji-repo-hint { font-size: 0.75rem; color: var(--ink-4); }
.ji-repo-hint code { font-size: 0.75rem; color: var(--ink-3); }

/* Content */
.ji-content {
  padding: 1.25rem;
  max-width: none;
}
/* Boost Java code blocks inside this section */
.ji-content pre {
  border: 1px solid rgba(232,160,48,0.15);
}
.ji-content h3 {
  font-size: 1rem;
  color: var(--java-accent);
  margin-top: 1.5rem;
  margin-bottom: 0.5rem;
  padding-bottom: 0.35rem;
  border-bottom: 1px solid rgba(232,160,48,0.15);
}
</style>
