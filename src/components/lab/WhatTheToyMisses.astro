---
interface MissItem { thing: string; why: string; }
interface Props { items: MissItem[]; }
const { items } = Astro.props;
---
<div class="toy-misses">
  <div class="misses-header">
    <span class="misses-label">What the toy misses</span>
    <span class="misses-sub">Honest gaps vs. production</span>
  </div>
  <ul class="misses-list">
    {items.map(item => (
      <li class="miss-item">
        <span class="miss-thing">{item.thing}</span>
        <span class="miss-why">{item.why}</span>
      </li>
    ))}
  </ul>
</div>

<style>
.toy-misses {
  border: 1px solid var(--line-2);
  border-radius: var(--r-md);
  overflow: hidden;
  margin: 1.5rem 0;
}
.misses-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 0.75rem 1rem;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--line);
}
.misses-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ink-3);
}
.misses-sub { font-size: 0.75rem; color: var(--ink-4); }

.misses-list { list-style: none; padding: 0; }
.miss-item {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 0.75rem;
  padding: 0.65rem 1rem;
  border-bottom: 1px solid var(--line);
  align-items: start;
}
.miss-item:last-child { border-bottom: none; }
.miss-thing {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--ink-2);
}
.miss-why { font-size: 0.82rem; color: var(--ink-3); line-height: 1.5; }
</style>
