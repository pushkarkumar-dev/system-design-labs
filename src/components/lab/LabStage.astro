---
interface Props {
  id: 'v0' | 'v1' | 'v2' | 'v3';
  title: string;
  goals: string[];
  loc?: number;
  tag?: string;
}
const { id, title, goals, loc, tag } = Astro.props;
const stageLabels = { v0: 'Stage 0', v1: 'Stage 1', v2: 'Stage 2', v3: 'Stage 3' };
---
<details class={`lab-stage lab-stage--${id}`}>
  <summary class="stage-summary">
    <span class="stage-id">{stageLabels[id]}</span>
    <span class="stage-title">{title}</span>
    <span class="stage-meta">
      {loc && <span class="stage-loc">~{loc} LoC</span>}
      {tag && <code class="stage-tag">{tag}</code>}
      <span class="stage-chevron">›</span>
    </span>
  </summary>
  <div class="stage-body">
    <ul class="stage-goals">
      {goals.map(g => <li>{g}</li>)}
    </ul>
    <div class="stage-content">
      <slot />
    </div>
  </div>
</details>

<style>
.lab-stage {
  border-radius: var(--r-md);
  border: 1px solid var(--line);
  margin-bottom: 1rem;
  overflow: hidden;
}
.lab-stage--v0 { border-left: 3px solid #8fb086; }
.lab-stage--v1 { border-left: 3px solid #7aa6c2; }
.lab-stage--v2 { border-left: 3px solid var(--accent); }
.lab-stage--v3 { border-left: 3px solid #d27a4f; }

.lab-stage[open] { background: var(--bg-card); }

.stage-summary {
  list-style: none;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1rem;
  cursor: pointer;
  user-select: none;
  gap: 0.75rem;
}
.stage-summary::-webkit-details-marker { display: none; }
.stage-summary:hover { background: var(--bg-raised); }

.stage-id {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  color: var(--ink-4);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  min-width: 4.5rem;
}
.lab-stage--v0 .stage-id { color: #8fb086; }
.lab-stage--v1 .stage-id { color: #7aa6c2; }
.lab-stage--v2 .stage-id { color: var(--accent); }
.lab-stage--v3 .stage-id { color: #d27a4f; }

.stage-title {
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--ink);
  flex: 1;
}

.stage-meta {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.stage-loc {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  color: var(--ink-4);
}
.stage-tag {
  font-size: 0.72rem;
  color: var(--ink-3);
  background: var(--bg-raised);
  border: 1px solid var(--line-2);
  border-radius: var(--r-sm);
  padding: 0.1rem 0.4rem;
}
.stage-chevron {
  font-size: 1rem;
  color: var(--ink-4);
  transition: transform var(--dur-fast);
}
details[open] .stage-chevron { transform: rotate(90deg); }

.stage-body { padding: 0 1rem 1rem 1rem; }

.stage-goals {
  list-style: none;
  padding: 0;
  margin-bottom: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.stage-goals li {
  font-size: 0.85rem;
  color: var(--ink-3);
  padding-left: 1.25rem;
  position: relative;
}
.stage-goals li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--accent);
  font-size: 0.8rem;
}
.stage-content { font-size: 0.9rem; }
</style>
