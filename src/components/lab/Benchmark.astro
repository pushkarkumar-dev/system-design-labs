---
interface BenchRow { metric: string; value: string; unit: string; note?: string; }
interface Props {
  hardware: string;
  rows: BenchRow[];
}
const { hardware, rows } = Astro.props;
---
<div class="benchmark">
  <div class="bench-header">
    <span class="bench-label">Benchmark results</span>
    <span class="bench-hw">on <code>{hardware}</code></span>
  </div>
  <table class="bench-table">
    <thead>
      <tr>
        <th>Metric</th>
        <th class="align-right">Result</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {rows.map(r => (
        <tr>
          <td class="metric-name">{r.metric}</td>
          <td class="metric-value align-right">
            <span class="value-number">{r.value}</span>
            <span class="value-unit"> {r.unit}</span>
          </td>
          <td class="metric-note">{r.note ?? '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
.benchmark {
  border: 1px solid var(--line-2);
  border-radius: var(--r-md);
  overflow: hidden;
  margin: 1.5rem 0;
}
.bench-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1rem;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--line);
}
.bench-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ink-3);
}
.bench-hw { font-size: 0.78rem; color: var(--ink-4); }
.bench-hw code { background: none; border: none; padding: 0; color: var(--ink-3); }

.bench-table { width: 100%; border-collapse: collapse; }
.bench-table th {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--ink-4);
  padding: 0.5rem 1rem;
  text-align: left;
  border-bottom: 1px solid var(--line);
}
.bench-table td {
  padding: 0.6rem 1rem;
  border-bottom: 1px solid var(--line);
  font-size: 0.88rem;
}
.bench-table tr:last-child td { border-bottom: none; }

.metric-name { color: var(--ink-2); font-weight: 500; }
.metric-value { white-space: nowrap; }
.align-right { text-align: right; }
.value-number {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.92rem;
  color: var(--accent);
  font-weight: 600;
}
.value-unit { color: var(--ink-4); font-size: 0.8rem; }
.metric-note { color: var(--ink-4); font-size: 0.82rem; }
</style>
