---
interface Props { insight: string; }
const { insight } = Astro.props;
---
<aside class="surprised">
  <span class="surprised-label">What surprised me</span>
  <p class="surprised-text"><slot>{insight}</slot></p>
</aside>

<style>
.surprised {
  border-left: 3px solid var(--accent);
  background: var(--accent-soft);
  border-radius: 0 var(--r-md) var(--r-md) 0;
  padding: 1rem 1.25rem;
  margin: 1.5rem 0;
}
.surprised-label {
  display: block;
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  margin-bottom: 0.5rem;
}
.surprised-text {
  font-size: 0.92rem;
  color: var(--ink-2);
  line-height: 1.65;
  margin: 0;
  font-style: italic;
}
</style>
