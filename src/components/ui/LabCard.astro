---
import Badge from './Badge.astro';
interface Props {
  slug: string;
  title: string;
  category: string;
  difficulty: 'intermediate' | 'advanced' | 'extreme';
  language: 'rust' | 'go' | 'python' | 'java' | 'c' | 'zig' | 'mixed';
  estimatedHours: { reading: number; building: number };
  topBenchmark?: string;
  summary: string;
  published?: boolean;
}
const { slug, title, category, difficulty, language, estimatedHours, topBenchmark, summary, published = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = published ? `${base}/${slug}` : undefined;
const Tag = published ? 'a' : 'div';
---
<Tag href={href} class={`lab-card ${published ? 'lab-card--live' : 'lab-card--soon'}`}>
  <div class="card-top">
    <Badge variant="lang" lang={language} label={language} />
    <Badge variant="diff" diff={difficulty} label={difficulty} />
    {!published && <span class="coming-soon">soon</span>}
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-summary">{summary}</p>
  <div class="card-meta">
    <span class="meta-item">
      <span class="meta-icon">⏱</span>
      {estimatedHours.building}h build
    </span>
    {topBenchmark && (
      <span class="meta-item meta-bench">
        <span class="meta-icon">⚡</span>
        {topBenchmark}
      </span>
    )}
    <span class="meta-cat">{category}</span>
  </div>
</Tag>

<style>
.lab-card {
  display: block;
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: var(--r-md);
  padding: 1.25rem;
  text-decoration: none;
  color: inherit;
  transition: border-color var(--dur-fast), background var(--dur-fast), transform var(--dur-fast);
  cursor: default;
}
.lab-card--live {
  cursor: pointer;
}
.lab-card--live:hover {
  border-color: var(--accent-line);
  background: var(--bg-raised);
  transform: translateY(-1px);
  text-decoration: none;
}
.lab-card--soon { opacity: 0.5; }

.card-top {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}
.coming-soon {
  font-size: 0.65rem;
  font-family: 'JetBrains Mono', monospace;
  color: var(--ink-4);
  margin-left: auto;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.card-title {
  font-family: 'Source Serif 4 Variable', Georgia, serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 0.5rem;
  line-height: 1.35;
}
.lab-card--soon .card-title { color: var(--ink-3); }

.card-summary {
  font-size: 0.83rem;
  color: var(--ink-3);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 0.875rem;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.meta-item {
  font-size: 0.75rem;
  color: var(--ink-4);
  font-family: 'JetBrains Mono', monospace;
  display: flex;
  align-items: center;
  gap: 0.3rem;
}
.meta-bench { color: var(--accent); }
.meta-cat {
  margin-left: auto;
  font-size: 0.72rem;
  color: var(--ink-4);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
</style>
