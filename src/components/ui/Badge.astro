---
interface Props {
  variant?: 'lang' | 'diff' | 'stage' | 'default';
  lang?: 'rust' | 'go' | 'python' | 'java' | 'c' | 'zig' | 'mixed';
  diff?: 'intermediate' | 'advanced' | 'extreme';
  stage?: 'v0' | 'v1' | 'v2' | 'v3';
  label: string;
}
const { variant = 'default', lang, diff, stage, label } = Astro.props;
const cls = [
  'badge',
  variant === 'lang' && lang  ? `badge-lang badge-lang-${lang}` : '',
  variant === 'diff' && diff  ? `badge-diff badge-diff-${diff}` : '',
  variant === 'stage' && stage ? `badge-stage badge-stage-${stage}` : '',
  variant === 'default' ? 'badge-default' : '',
].filter(Boolean).join(' ');
---
<span class={cls}>{label}</span>

<style>
.badge {
  display: inline-flex;
  align-items: center;
  font-size: 0.72rem;
  font-family: 'JetBrains Mono', monospace;
  font-weight: 500;
  padding: 0.2rem 0.55rem;
  border-radius: 999px;
  border: 1px solid transparent;
  white-space: nowrap;
  letter-spacing: 0.03em;
}

/* language badges */
.badge-lang-rust   { background: rgba(206, 66, 43,  0.12); color: #e06050; border-color: rgba(206, 66, 43,  0.25); }
.badge-lang-go     { background: rgba(0,  172, 215, 0.10); color: #4ab8d8; border-color: rgba(0,  172, 215, 0.22); }
.badge-lang-python { background: rgba(53, 114, 165, 0.12); color: #7aa8d0; border-color: rgba(53, 114, 165, 0.25); }
.badge-lang-java   { background: rgba(232,160, 48,  0.12); color: #e8a030; border-color: rgba(232,160, 48,  0.30); }
.badge-lang-c      { background: rgba(85, 85, 85,   0.15); color: #aaaaaa; border-color: rgba(85, 85, 85,   0.30); }
.badge-lang-zig    { background: rgba(236,145, 92,  0.12); color: #ec915c; border-color: rgba(236,145, 92,  0.25); }
.badge-lang-mixed  { background: var(--accent-soft); color: var(--accent); border-color: var(--accent-line); }

/* difficulty */
.badge-diff-intermediate { background: rgba(143,176,134,0.12); color: #8fb086; border-color: rgba(143,176,134,0.25); }
.badge-diff-advanced     { background: rgba(224,169,109,0.12); color: #e0a96d; border-color: rgba(224,169,109,0.25); }
.badge-diff-extreme      { background: rgba(210,122, 79,0.12); color: #d27a4f; border-color: rgba(210,122, 79,0.25); }

/* stage */
.badge-stage-v0  { background: var(--stage-v0); color: #8fb086; border-color: rgba(143,176,134,0.3); }
.badge-stage-v1  { background: var(--stage-v1); color: #7aa6c2; border-color: rgba(122,166,194,0.3); }
.badge-stage-v2  { background: var(--stage-v2); color: #e0a96d; border-color: rgba(232,184,122,0.3); }
.badge-stage-v3  { background: var(--stage-v3); color: #d27a4f; border-color: rgba(210,122, 79,0.3); }

/* default */
.badge-default { background: var(--bg-raised); color: var(--ink-3); border-color: var(--line-2); }
</style>
