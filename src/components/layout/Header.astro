---
const base = import.meta.env.BASE_URL;
---
<header class="site-header">
  <div class="header-inner">
    <a href={base} class="wordmark">
      <span class="wordmark-primary">build</span><span class="wordmark-accent">.</span><span class="wordmark-secondary">labs</span>
    </a>
    <nav class="header-nav">
      <a href="https://pushkarkumar-dev.github.io" class="nav-back" target="_blank" rel="noopener">
        ← pushkar.dev
      </a>
      <a href="https://pushkarkumar-dev.github.io/system-design" class="nav-link" target="_blank" rel="noopener">
        System Design
      </a>
      <a href={`${base}#labs`} class="nav-link">Labs</a>
    </nav>
    <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme" title="Toggle theme">
      <span class="theme-icon-sun">☀</span>
      <span class="theme-icon-moon">☽</span>
    </button>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(10, 10, 10, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--line);
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  height: 56px;
  display: flex;
  align-items: center;
  gap: 1.5rem;
}
.wordmark {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1rem;
  font-weight: 500;
  text-decoration: none;
  display: flex;
  align-items: center;
}
.wordmark-primary  { color: var(--ink); }
.wordmark-accent   { color: var(--accent); font-size: 1.2rem; }
.wordmark-secondary{ color: var(--ink-3); }

.header-nav {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  margin-left: auto;
}
.nav-back {
  font-size: 0.8rem;
  color: var(--ink-3);
  text-decoration: none;
  border: 1px solid var(--line-2);
  border-radius: 999px;
  padding: 0.25rem 0.75rem;
  transition: color var(--dur-fast), border-color var(--dur-fast);
}
.nav-back:hover { color: var(--ink); border-color: var(--accent-line); text-decoration: none; }
.nav-link {
  font-size: 0.85rem;
  color: var(--ink-3);
  text-decoration: none;
  transition: color var(--dur-fast);
}
.nav-link:hover { color: var(--ink); text-decoration: none; }

.theme-btn {
  background: none;
  border: 1px solid var(--line-2);
  border-radius: var(--r-sm);
  color: var(--ink-3);
  cursor: pointer;
  padding: 0.3rem 0.5rem;
  font-size: 0.9rem;
  transition: color var(--dur-fast), border-color var(--dur-fast);
}
.theme-btn:hover { color: var(--ink); border-color: var(--accent-line); }
html:not([data-theme='light']) .theme-icon-sun { display: none; }
html[data-theme='light']       .theme-icon-moon { display: none; }
</style>

<script is:inline>
document.getElementById('theme-toggle')?.addEventListener('click', () => {
  const html = document.documentElement;
  const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
});
</script>
